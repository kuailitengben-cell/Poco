rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isBanned() {
      // Safely check if the current user's profile has isBanned: true
      return isSignedIn() && 
             exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('isBanned', false) == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidScene(data, isCreate) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'authorPhoto', 'createdAt', 'upvotes']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 2000 &&
             (!data.keys().hasAll(['imageUrl']) || data.imageUrl == null || data.imageUrl is string) &&
             (!data.keys().hasAll(['hashtags']) || data.hashtags is list) &&
             (!data.keys().hasAll(['views']) || data.views is int) &&
             data.authorId == request.auth.uid &&
             data.createdAt == (isCreate ? request.time : existing().createdAt) &&
             data.upvotes is int && (isCreate ? data.upvotes == 0 : true) &&
             (isCreate ? (!data.keys().hasAll(['views']) || data.views == 0) : true);
    }

    function isValidFollow(data) {
      return data.followerId == request.auth.uid;
    }

    function isValidChat(data) {
      return (request.auth.uid in data.participants);
    }

    function isValidMessage(data, chatId) {
      return data.senderId == request.auth.uid;
    }

    function isValidComment(data) {
      return data.authorId == request.auth.uid;
    }

    function isValidUpvote(data) {
      return data.userId == request.auth.uid;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['displayName', 'photoURL']) &&
             data.keys().size() >= 2 && data.keys().size() <= 60 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.photoURL is string &&
             (!data.keys().hasAll(['bio']) || data.bio == null || data.bio is string) &&
             (!data.keys().hasAll(['updatedAt']) || data.updatedAt == null || data.updatedAt is timestamp || data.updatedAt is string) &&
             (!data.keys().hasAll(['isBanned']) || data.isBanned is bool) &&
             (!data.keys().hasAll(['lastReadAnnouncementId']) || data.lastReadAnnouncementId is string) &&
             (!data.keys().hasAll(['lastActiveAt']) || data.lastActiveAt is timestamp || data.lastActiveAt is string) &&
             (!data.keys().hasAll(['selectedTitle']) || data.selectedTitle == null || data.selectedTitle is string) &&
             (!data.keys().hasAll(['equippedBadges']) || data.equippedBadges is list) &&
             (!data.keys().hasAll(['postsCount']) || data.postsCount is int || data.postsCount == null) &&
             (!data.keys().hasAll(['deletedPostsCount']) || data.deletedPostsCount is int || data.deletedPostsCount == null) &&
             (!data.keys().hasAll(['loginStreak']) || data.loginStreak is int || data.loginStreak == null) &&
             (!data.keys().hasAll(['lastLoginDate']) || data.lastLoginDate is string || data.lastLoginDate == null) &&
             (!data.keys().hasAll(['totalLoginDays']) || data.totalLoginDays is int || data.totalLoginDays == null) &&
             (!data.keys().hasAll(['viewsCount']) || data.viewsCount is int || data.viewsCount == null) &&
             (!data.keys().hasAll(['upvotesReceived']) || data.upvotesReceived is int || data.upvotesReceived == null) &&
             (!data.keys().hasAll(['maxUpvotesOnSinglePost']) || data.maxUpvotesOnSinglePost is int || data.maxUpvotesOnSinglePost == null) &&
             (!data.keys().hasAll(['midnightPostsCount']) || data.midnightPostsCount is int || data.midnightPostsCount == null) &&
             (!data.keys().hasAll(['commentRate']) || data.commentRate is int || data.commentRate is float || data.commentRate == null) &&
             (!data.keys().hasAll(['weekdayDaytimePostsCount']) || data.weekdayDaytimePostsCount is int || data.weekdayDaytimePostsCount == null) &&
             (!data.keys().hasAll(['midnightActiveStreak']) || data.midnightActiveStreak is int || data.midnightActiveStreak == null) &&
             (!data.keys().hasAll(['commentsBlockedCount']) || data.commentsBlockedCount is int || data.commentsBlockedCount == null) &&
             (!data.keys().hasAll(['gachaWon']) || data.gachaWon is bool || data.gachaWon == null) &&
             (!data.keys().hasAll(['returnedAfter30Days']) || data.returnedAfter30Days is bool || data.returnedAfter35Days == null) &&
             (!data.keys().hasAll(['opsSecret']) || data.opsSecret is bool || data.opsSecret == null) &&
             (!data.keys().hasAll(['myCommentsCount']) || data.myCommentsCount is int || data.myCommentsCount == null) &&
             (!data.keys().hasAll(['isTopPercentile']) || data.isTopPercentile is bool || data.isTopPercentile == null) &&
             (!data.keys().hasAll(['registeredAt']) || data.registeredAt is timestamp || data.registeredAt is string || data.registeredAt == null) &&
             (!data.keys().hasAll(['hasSeenTutorial']) || data.hasSeenTutorial is bool || data.hasSeenTutorial == null) &&
             (!data.keys().hasAll(['midnightViewsCount']) || data.midnightViewsCount is int || data.midnightViewsCount == null) &&
             (!data.keys().hasAll(['unlockedPrefixIds']) || data.unlockedPrefixIds is list) &&
             (!data.keys().hasAll(['unlockedSuffixIds']) || data.unlockedSuffixIds is list) &&
             (!data.keys().hasAll(['unlockedBadgeIds']) || data.unlockedBadgeIds is list) &&
             (!data.keys().hasAll(['celebratedBadgeIds']) || data.celebratedBadgeIds is list) &&
             (!data.keys().hasAll(['celebratedPrefixIds']) || data.celebratedPrefixIds is list) &&
             (!data.keys().hasAll(['celebratedSuffixIds']) || data.celebratedSuffixIds is list) &&
             (!data.keys().hasAll(['coins']) || data.coins is int) &&
             (!data.keys().hasAll(['shards']) || data.shards is int);
    }

    match /scenes/{sceneId} {
      allow list, get: if true;
      allow create: if isSignedIn() && !isBanned() && isValidScene(incoming(), true) && isValidId(sceneId);
      
      allow update: if (
        // Action: Increment view count
        (incoming().diff(existing()).affectedKeys().hasOnly(['views']) &&
         incoming().get('views', 1) == existing().get('views', 0) + 1)
      ) || (
        isSignedIn() && !isBanned() && (
          // Action: Upvote/Un-upvote
          (incoming().diff(existing()).affectedKeys().hasOnly(['upvotes']) && 
           (incoming().upvotes == existing().upvotes + 1 || incoming().upvotes == existing().upvotes - 1)) ||
          // Action: Edit (owner only)
          (isOwner(existing().authorId) && 
           isValidScene(incoming(), false) &&
           incoming().upvotes == existing().upvotes
          ) ||
          // Action: Profile Sync (owner only updates metadata)
          (isOwner(existing().authorId) && 
           incoming().diff(existing()).affectedKeys().hasAll(['authorName', 'authorPhoto']) &&
           incoming().authorName is string && incoming().authorPhoto is string
          )
        )
      );
      
      allow delete: if isOwner(existing().authorId) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && !isBanned() && isValidComment(incoming()) && isValidId(commentId);
        allow update: if isOwner(existing().authorId) && 
                         incoming().diff(existing()).affectedKeys().hasAll(['authorName', 'authorPhoto']);
        allow delete: if isOwner(existing().authorId) || isAdmin();
      }
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidFollow(incoming());
      allow delete: if isSignedIn() && isOwner(existing().followerId);
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && isValidMessage(incoming(), chatId) && 
                         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /profiles/{userId} {
      allow read: if true;
      allow update: if (
        isOwner(userId) && 
        (!existing().keys().hasAll(['isBanned']) || existing().isBanned == false) &&
        isValidProfile(incoming()) && 
        (!incoming().keys().hasAll(['isBanned']) || incoming().isBanned == (existing().keys().hasAll(['isBanned']) ? existing().isBanned : false))
      ) || isAdmin();
      allow create: if isOwner(userId) && isValidProfile(incoming());
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isOwner(userId) && request.auth.token.email == 'kuailitengben@gmail.com');
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && !isBanned();
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /admin_messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.recipientId || isAdmin());
      allow create: if isAdmin();
      allow update: if isSignedIn() && request.auth.uid == resource.data.recipientId && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    match /upvotes/{upvoteId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidUpvote(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
    
    match /test/connection {
      allow get: if true;
    }
  }
}

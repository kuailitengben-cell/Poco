rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        ( 'email' in request.auth.token && (
          request.auth.token.email == 'kuailitengben@gmail.com' ||
          request.auth.token.email == 'nakashi198006130423@gmail.com'
        )) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isBanned() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('isBanned', false) == true;
    }

    // Validation definitions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Matches for each collection
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /scenes/{sceneId} {
      allow read, list: if true;
      allow create: if isSignedIn() && !isBanned();
      allow update: if (isSignedIn() && !isBanned()) || isAdmin();
      allow delete: if (isSignedIn() && !isBanned()) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && !isBanned();
        allow update, delete: if isSignedIn() && !isBanned();
      }
    }

    match /upvotes/{upvoteId} {
      allow read, list: if true;
      allow create: if isSignedIn() && !isBanned();
      allow delete: if isSignedIn() && !isBanned();
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && !isBanned();
      allow delete: if isSignedIn() && !isBanned();
    }

    match /chats/{chatId} {
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && !isBanned();

      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow create: if isSignedIn() && !isBanned() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && !isBanned();
      allow delete: if isAdmin();
    }

    match /admin_messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.recipientId || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid || request.resource.data.senderId == 'system_kairanban' || isAdmin());
      allow update: if isSignedIn() && request.auth.uid == resource.data.recipientId;
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /legal_documents/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /plaza_surveys/{surveyId} {
      allow read: if true;
      allow create: if isSignedIn() && !isBanned();
      allow update: if isSignedIn() && !isBanned();
      allow delete: if isAdmin();

      match /votes/{voteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && !isBanned();
        allow update, delete: if isSignedIn() && !isBanned();
      }
    }

    match /plaza_submissions/{subId} {
      allow read, list: if true;
      allow create, update: if isSignedIn() && !isBanned();
      allow delete: if isAdmin();
    }

    match /plaza_votes/{voteId} {
      allow read, list: if isSignedIn();
      allow create, update: if isSignedIn() && !isBanned();
      allow delete: if isAdmin();
    }

    match /plaza_books/{bookId} {
      allow read, list: if true;
      allow create, update: if isSignedIn() && !isBanned();
      allow delete: if isAdmin();
    }

    match /jse_reports/{reportId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /jse_global_trades/{tradeId} {
      allow read: if true;
      allow create: if isSignedIn() && !isBanned();
      allow update, delete: if isAdmin();
    }

    match /gift_codes/{codeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /gift_redemptions/{redemptionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isBanned();
      allow update, delete: if isAdmin();
    }

    match /login_bonuses/{bonusId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /login_claims/{claimId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isBanned();
      allow update, delete: if isSignedIn() && !isBanned();
    }

    match /gacha_pools/{poolId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /customBadges/{badgeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /customTitleParts/{partId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /campaignClaims/{claimId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isBanned() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /jse_creation_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.founderId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && !isBanned() && request.resource.data.founderId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && !isBanned() && resource.data.founderId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /jse_custom_stocks/{stockId} {
      allow read: if true;
      allow create: if isSignedIn() && !isBanned() && request.resource.data.founderId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && !isBanned() && resource.data.founderId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /jse_founder_rewards/{rewardId} {
      allow read: if isSignedIn() && (resource.data.founderId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && !isBanned() && request.resource.data.founderId == request.auth.uid;
      allow update: if isSignedIn() && !isBanned() && resource.data.founderId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /jse_config/{configId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /kaiwais/{kaiwaiId} {
      allow read, list: if true;
      allow create: if isAdmin() || (isSignedIn() && !isBanned());
      allow update: if isAdmin() || (isSignedIn() && !isBanned());
      allow delete: if isAdmin();
    }

    match /kaiwai_requests/{requestId} {
      allow read, list: if true;
      allow create: if isSignedIn() && !isBanned() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && !isBanned() && resource.data.creatorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /kaiwai_request_logs/{logId} {
      allow read, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /kaiwai_follows/{followId} {
      allow read, list: if true;
      allow create: if isSignedIn() && !isBanned() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && !isBanned() && resource.data.userId == request.auth.uid;
    }

    match /test/connection {
      allow get: if true;
    }
  }
}
